# Browser login credentials for job sites
# Rename to secrets.yml (gitignored) and fill in your credentials.
#
# Keys are domains (normalized — no www, no subdomains).
# See sites.yml for the corresponding login automation config (selectors, etc.)
#
# Domain normalization examples:
#   www.linkedin.com    →  linkedin.com
#   jobs.lever.co       →  lever.co
#   boards.greenhouse.io → greenhouse.io

linkedin.com:
  username: your_email@example.com
  password: your_password

indeed.com:
  username: your_email@example.com
  password: your_password

# Add more sites as needed:
# glassdoor.com:
#   username: your_email@example.com
#   password: your_password
